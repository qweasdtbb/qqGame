-- ===== 工具 =====
local function safe(cb)local o,k=pcall(cb)return o end
local function st(a,b)firetouchinterest(a,b,0)task.wait(.05)firetouchinterest(a,b,1)end
local function closest(t)
    local b,d=nil,9e9 for _,v in pairs(t)do
        if v.Parent and (v.Position-Root.Position).Magnitude<d then b,d=v,(v.Position-Root.Position).Magnitude end
    end return b
end
local function scanOres()local t={}for _,v in pairs(workspace:GetDescendants())do if v:IsA("BasePart")and v.Name:lower():find("ore")then table.insert(t,v)end end return t end
local function scanTrees()local t={}for _,v in pairs(workspace:GetDescendants())do if v:IsA("BasePart")and v.Name:lower():find("tree")then table.insert(t,v)end end return t end
local function scanGW()local t={}for _,v in pairs(workspace:GetDescendants())do if v:IsA("BasePart")then local n=v.Name:lower()if n:find("glacier")or n:find("ice")or n:find("frost")then table.insert(t,v)end end end return t end
local function scanMyWood()local t,uid={},LP.UserId for _,v in pairs(workspace:GetDescendants())do if v:IsA("BasePart")and v.Name:lower():find("wood")then for _,c in pairs(v:GetChildren())do if c:IsA("ObjectValue")and c.Value==LP then table.insert(t,v)break end end end end return t end
local function scanMeteors()local t={}for _,v in pairs(workspace:GetDescendants())do if v:IsA("BasePart")and v.Name:lower():find("meteor")then table.insert(t,v)end end return t end
local function findPart(n)
    for _,v in pairs(workspace:GetDescendants())do
        if v:IsA("BasePart")and v.Name:lower():find(n)then return v end
    end
    return nil
end
local function selectNearest(what)
    if what=="furnace"then SelectedFurnace=findPart("furnace")or findPart("smelt")end
    if what=="polish"then SelectedPolisher=findPart("polish")end
    if what=="process"then SelectedProcessor=findPart("wood")or findPart("plank")or findPart("process")end
end

