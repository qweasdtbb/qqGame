local currentOre,currentTree,currentGlacier=nil,nil,nil
RunService.RenderStepped:Connect(function()
    simulateWalk()
    if _G.Settings.AutoMine then if not currentOre then currentOre=getClosest(scanOres())end if currentOre then remoteMine(currentOre)end else currentOre=nil end
    if _G.Settings.AutoChop then if not currentTree or not isTreeAlive(currentTree)then currentTree=getClosest(scanGlacierWood())or getClosest(scanTrees())end if currentTree then remoteChop(currentTree)end else currentTree=nil end
    if _G.Settings.AutoGlacierWood then if not currentGlacier or not isTreeAlive(currentGlacier)then currentGlacier=getClosest(scanGlacierWood())end if currentGlacier then remoteChopGlacier(currentGlacier)end else currentGlacier=nil end
end)

