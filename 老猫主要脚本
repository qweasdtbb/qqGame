-- ===== 主循环 =====
RunService.RenderStepped:Connect(function()
    if _G.Settings.AutoMine then local o=closest(scanOres())if o then st(Root,o)end end
    if _G.Settings.AutoChop then local t=closest(scanTrees())if t then st(Root,t)end end
    if _G.Settings.AutoGlacierWood then local w=closest(scanGW())if w then st(Root,w)end end
end)

task.spawn(function()while task.wait(2)do
    if _G.Settings.AutoSmelt and SelectedFurnace then
        for _,o in pairs(scanOres())do safe(function()st(o,SelectedFurnace)end)task.wait(.3)end
    end
end end)

task.spawn(function()while task.wait(2)do
    if _G.Settings.AutoPolish and SelectedPolisher then
        for _,o in pairs(scanOres())do safe(function()st(o,SelectedPolisher)end)task.wait(.3)end
    end
end end)

task.spawn(function()while task.wait(2)do
    if _G.Settings.AutoProcess and SelectedProcessor then
        for _,w in pairs(scanMyWood())do safe(function()st(w,SelectedProcessor)end)task.wait(.3)end
    end
end end)

task.spawn(function()while task.wait(1)do
    if _G.Settings.AutoMeteor then local m=closest(scanMeteors())if m then Root.CFrame=m.CFrame+Vector3.new(0,4,0)end end
end end)

