local function safeTouch(a,b)firetouchinterest(a,b,0)task.wait(0.05)firetouchinterest(a,b,1)end
local function simulateWalk()local h=Character:FindFirstChildOfClass("Humanoid")if h then h:ChangeState(Enum.HumanoidStateType.Running)end end
local function getClosest(tbl)local b,d=nil,math.huge for _,v in pairs(tbl)do local dist=(v.Position-RootPart.Position).Magnitude if dist<d then b,d=v,dist end end return b,d end
local function scanOres()local t={}for _,v in pairs(Workspace:GetDescendants())do if v:IsA("BasePart")and v.Name:lower():find("ore")then table.insert(t,v)end end return t end
local function scanTrees()local t={}for _,v in pairs(Workspace:GetDescendants())do if v:IsA("BasePart")and v.Name:lower():find("tree")then table.insert(t,v)end end return t end
local function scanGlacierWood()local t={}for _,v in pairs(Workspace:GetDescendants())do if v:IsA("BasePart")then local n=v.Name:lower()if n:find("glacier")or n:find("ice")or n:find("frozen")or n:find("frost")then table.insert(t,v)end end end return t end
local function scanMyWood()local t,uid={},LocalPlayer.UserId for _,v in pairs(Workspace:GetDescendants())do if v:IsA("BasePart")and v.Name:lower():find("wood")then for _,c in pairs(v:GetChildren())do if c:IsA("ObjectValue")and c.Value==LocalPlayer then table.insert(t,v)break elseif c:IsA("IntValue")and c.Value==uid then table.insert(t,v)break end end end end return t end
local function scanMeteors()local t={}for _,v in pairs(Workspace:GetDescendants())do if v:IsA("BasePart")and v.Name:lower():find("meteor")then table.insert(t,v)end end return t end
local function scanFurnace()for _,v in pairs(Workspace:GetDescendants())do if v:IsA("BasePart")and v.Name:lower():find("furnace")then return v end end return nil end
local function scanPolisher()for _,v in pairs(Workspace:GetDescendants())do if v:IsA("BasePart")and v.Name:lower():find("polish")then return v end end return nil end
local function scanUnpacker()for _,v in pairs(Workspace:GetDescendants())do if v:IsA("BasePart")or v:IsA("Model")then local n=v.Name:lower()if n:find("unpack")or n:find("saw")or n:find("plank")or n:find("workbench")then return v:IsA("BasePart")and v or v:FindFirstChildWhichIsA("BasePart")end end end return nil end
local function scanWoodProcessor()for _,v in pairs(Workspace:GetDescendants())do if v:IsA("BasePart")and v.Name:lower():find("wood")then return v end end return nil end
local function getTreeHealth(t)for _,n in pairs({"Health","HP","Integrity","Strength","IceStrength"})do local v=t:FindFirstChild(n)if v and v:IsA("ValueBase")then return v.Value end end return nil end
local function isTreeAlive(t)local hp=getTreeHealth(t)if hp then return hp>0 end return t and t.Parent~=nil end
local function remoteMine(o)if not o then return end task.spawn(function()for i=1,5 do safeTouch(RootPart,o)task.wait(0.2)end end)end
local function remoteChop(t)if not t then return end task.spawn(function()for i=1,6 do safeTouch(RootPart,t)task.wait(0.15)end end)end
local function remoteChopGlacier(w)if not w then return end task.spawn(function()for i=1,6 do safeTouch(RootPart,w)task.wait(0.15)end end)end
local function predictLandingPoint(m)local vel=m.AssemblyLinearVelocity local pos=m.Position local ttl=pos.Y/math.abs(vel.Y)return pos+vel*ttl end
local function safeTeleport(p)local h=Character:FindFirstChildOfClass("Humanoid")if h then h.WalkSpeed=16 h:MoveTo(p)end task.wait(0.5)RootPart.CFrame=CFrame.new(p+Vector3.new(0,5,0))end
local SelectedItems={}
local function quickTouch(i)if not i then return end firetouchinterest(RootPart,i,0)task.wait(0.03)firetouchinterest(RootPart,i,1)end
local function pushItem(i,t)if not i:IsA("BasePart")then return end for x=1,20 do local dir=(t-i.Position).Unit i.CFrame=i.CFrame+dir*0.4 task.wait()end end
local function transportItems(n)local tp=TeleportPoints[n]if not tp then return end if #SelectedItems==0 then return end local b={}for idx,it in pairs(SelectedItems)do if it and it.Parent then table.insert(b,it)if #b==_G.Settings.TransportBatchSize or idx==#SelectedItems then for _,v in pairs(b)do quickTouch(v)end task.wait(0.3)for _,v in pairs(b)do task.spawn(function()pushItem(v,tp)end)end task.wait(1.5)table.clear(b)end end end end

