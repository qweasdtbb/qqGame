-- 移动鼠标到指定位置
local function moveMouse(x, y)
    local success = pcall(function()
        -- 使用 VirtualInput 模拟鼠标移动
        UIS:SendMouseMoveEvent(Vector2.new(x, y))
    end)
    if success then
        mouseStates.position = Vector2.new(x, y)
        print("🖱 鼠标移动到: " .. x .. ", " .. y)
    end
    return success
end

-- 相对移动鼠标
local function moveMouseDelta(dx, dy)
    local newX = mouseStates.position.X + dx
    local newY = mouseStates.position.Y + dy
    return moveMouse(newX, newY)
end

-- 鼠标点击
local function clickMouse(button, clickType)
    button = button or "MouseButton1"
    clickType = clickType or "Single"
    
    local success = pcall(function()
        if clickType == "Double" then
            -- 双击
            UIS:SendMouseButtonEvent(button, Enum.UserInputState.Begin)
            task.wait(0.03)
            UIS:SendMouseButtonEvent(button, Enum.UserInputState.End)
            task.wait(0.08)
            UIS:SendMouseButtonEvent(button, Enum.UserInputState.Begin)
            task.wait(0.03)
            UIS:SendMouseButtonEvent(button, Enum.UserInputState.End)
        elseif clickType == "Hold" then
            -- 按住
            UIS:SendMouseButtonEvent(button, Enum.UserInputState.Begin)
        elseif clickType == "Release" then
            -- 释放
            UIS:SendMouseButtonEvent(button, Enum.UserInputState.End)
        else
            -- 单击
            UIS:SendMouseButtonEvent(button, Enum.UserInputState.Begin)
            task.wait(0.03)
            UIS:SendMouseButtonEvent(button, Enum.UserInputState.End)
        end
    end)
    
    if success then
        local btnName = button == "MouseButton1" and "左键" or 
                       button == "MouseButton2" and "右键" or "中键"
        print("🖱 鼠标" .. btnName .. " " .. clickType .. "点击")
    end
    return success
end

-- 左键点击
local function leftClick()
    return clickMouse("MouseButton1", "Single")
end

-- 右键点击
local function rightClick()
