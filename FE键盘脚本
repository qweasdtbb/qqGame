    end
    return success
end

-- ===============================
-- 组合操作函数
-- ===============================

-- 按键组合（如 Ctrl+C）
local function keyCombo(...)
    local keys = {...}
    local keyCodes = {}
    for _, k in ipairs(keys) do
        local kc = KEY_MAP[k:upper()]
        if kc then
            table.insert(keyCodes, kc)
        else
            warn("❌ 未知按键: " .. k)
            return false
        end
    end
    
    local success = pcall(function()
        -- 按下所有键
        for _, kc in ipairs(keyCodes) do
            UIS:SendKeyEvent(kc, Enum.UserInputState.Begin)
        end
        task.wait(0.05)
        -- 释放所有键（反向顺序）
        for i = #keyCodes, 1, -1 do
            UIS:SendKeyEvent(keyCodes[i], Enum.UserInputState.End)
        end
    end)
    
    if success then
        print("⌨️ 组合键: " .. table.concat(keys, "+"))
    end
    return success
end

-- Ctrl+C（复制）
local function copySelection()
    return keyCombo("CTRL", "C")
end

-- Ctrl+V（粘贴）
local function pasteSelection()
    return keyCombo("CTRL", "V")
end

-- Ctrl+A（全选）
local function selectAll()
    return keyCombo("CTRL", "A")
end

-- Alt+Tab（切换窗口）
local function altTab()
    return keyCombo("ALT", "TAB")
end

