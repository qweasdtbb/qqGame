-- 自动点击（连点）
local autoClickConn = nil
local autoClickEnabled = false
local autoClickInterval = 0.1

local function setAutoClick(enabled, interval)
    autoClickEnabled = enabled
    autoClickInterval = interval or 0.1
    if enabled then
        if autoClickConn then autoClickConn:Disconnect() end
        autoClickConn = RS.Heartbeat:Connect(function()
            pcall(function()
                UIS:SendMouseButtonEvent("MouseButton1", Enum.UserInputState.Begin)
                task.wait(0.02)
                UIS:SendMouseButtonEvent("MouseButton1", Enum.UserInputState.End)
            end)
            task.wait(autoClickInterval)
        end)
        print("🖱 自动点击: 已开启 | 间隔: " .. autoClickInterval .. "s")
    else
        if autoClickConn then
            autoClickConn:Disconnect()
            autoClickConn = nil
        end
        print("🖱 自动点击: 已关闭")
    end
end

-- 自动走路（W键持续按住）
local autoWalkConn = nil
local autoWalkEnabled = false

local function setAutoWalk(enabled)
    autoWalkEnabled = enabled
    if enabled then
        if autoWalkConn then autoWalkConn:Disconnect() end
        autoWalkConn = RS.Heartbeat:Connect(function()
            pcall(function()
                UIS:SendKeyEvent(Enum.KeyCode.W, Enum.UserInputState.Begin)
            end)
        end)
        print("⌨️ 自动走路: 已开启")
    else
        if autoWalkConn then
            autoWalkConn:Disconnect()
            autoWalkConn = nil
        end
        pcall(function()
            UIS:SendKeyEvent(Enum.KeyCode.W, Enum.UserInputState.End)
        end)
        print("⌨️ 自动走路: 已关闭")
    end
end

-- ===============================
-- 总开关
-- ===============================
local function setEnabled(state)
    isEnabled = state
    if not state then
        -- 关闭所有自动化
        setAutoClick(false)
        setAutoWalk(false)
        -- 释放所有按键
        for key, _ in pairs(keyStates) do
            local keyCode = KEY_MAP[key]
            if keyCode then
                pcall(function()
                    UIS:SendKeyEvent(keyCode, Enum.UserInputState.End)
                end)
            end
        end
        keyStates = {}
        -- 释放鼠标
        pcall(function()
            UIS:SendMouseButtonEvent("MouseButton1", Enum.UserInputState.End)
            UIS:SendMouseButtonEvent("MouseButton2", Enum.UserInputState.End)
        end)
        print("⏹ 键鼠模拟: 已关闭 | 所有操作已停止")
    else
        print("▶️ 键鼠模拟: 已开启")
    end
    return isEnabled
end

