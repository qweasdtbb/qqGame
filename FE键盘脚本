btn("🖱 左键单击", function()
    UIS:SendMouseButtonEvent(0,0,0,true,game)
    task.wait(0.03)
    UIS:SendMouseButtonEvent(0,0,0,false,game)
end)

btn("🖱 右键单击", function()
    UIS:SendMouseButtonEvent(0,0,1,true,game)
    task.wait(0.03)
    UIS:SendMouseButtonEvent(0,0,1,false,game)
end)

-- ===============================
-- 自动连点
-- ===============================
local clicking = false
btn("🔁 自动左键连点", function()
    clicking = not clicking
    if clicking then
        task.spawn(function()
            while clicking and SG and SG.Parent do
                pcall(function()
                    UIS:SendMouseButtonEvent(0,0,0,true,game)
                    task.wait(0.03)
                    UIS:SendMouseButtonEvent(0,0,0,false,game)
                end)
                task.wait(0.1)
            end
        end)
    end
end)

