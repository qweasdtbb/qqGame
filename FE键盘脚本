-- ===============================
-- 服务
-- ===============================
local UIS = game:GetService("UserInputService")
local Players = game:GetService("Players")
local Plr = Players.LocalPlayer
local PG = Plr:WaitForChild("PlayerGui")

-- ===============================
-- 安全创建 UI（防炸核心）
-- ===============================
local function safeCreate(class, props)
    local ok, obj = pcall(Instance.new, class)
    if not ok or not obj then return nil end
    for k, v in pairs(props or {}) do
        pcall(function() obj[k] = v end)
    end
    return obj
end

local SG = safeCreate("ScreenGui", {
    Name = "StableKeySim",
    ResetOnSpawn = false,
    IgnoreGuiInset = true,
    Parent = PG
})

if not SG then
    warn("❌ UI 创建失败")
    return
end

local Main = safeCreate("Frame", {
    Size = UDim2.new(0, 360, 0, 500),
    Position = UDim2.new(0.5, -180, 0.5, -250),
    BackgroundColor3 = Color3.fromRGB(25, 25, 35),
    BorderSizePixel = 0,
    Active = true,
    Parent = SG
})

if not Main then return end

Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 10)

-- ===============================
-- 拖拽（防抖 + 安全）
-- ===============================
local dragging, startPos
Main.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        startPos = i.Position
    end
end)

UIS.InputChanged:Connect(function(i)
    if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
        pcall(function()
            local d = i.Position - startPos
            Main.Position = UDim2.new(
                Main.Position.X.Scale,
                Main.Position.X.Offset + d.X,
                Main.Position.Y.Scale,
                Main.Position.Y.Offset + d.Y
            )
            startPos = i.Position
        end)
    end
end)

UIS.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

-- ===============================
-- 标题栏
-- ===============================
local Title = safeCreate("TextLabel", {
    Size = UDim2.new(1, -80, 0, 40),
    Position = UDim2.new(0, 10, 0, 0),
    BackgroundTransparency = 1,
    Text = "⌨️ 稳定键鼠模拟器",
