-- 按下键盘按键
local function pressKey(keyName, duration)
    duration = duration or 0.05
    local keyCode = KEY_MAP[keyName:upper()]
    if not keyCode then
        warn("❌ 未知按键: " .. keyName)
        return false
    end
    
    local success = pcall(function()
        -- 使用 VirtualInput 模拟按键
        local inputObj = {
            KeyCode = keyCode,
            UserInputType = Enum.UserInputType.Keyboard,
            UserInputState = Enum.UserInputState.Begin,
        }
        UIS:SendKeyEvent(keyCode, Enum.UserInputState.Begin)
        task.wait(duration)
        UIS:SendKeyEvent(keyCode, Enum.UserInputState.End)
    end)
    
    if success then
        print("⌨️ 按下按键: " .. keyName)
    else
        warn("❌ 按键失败: " .. keyName)
    end
    return success
end

-- 按住键盘按键（持续按住）
local function holdKey(keyName, holdTime)
    holdTime = holdTime or 1
    local keyCode = KEY_MAP[keyName:upper()]
    if not keyCode then
        warn("❌ 未知按键: " .. keyName)
        return false
    end
    
    local success = pcall(function()
        UIS:SendKeyEvent(keyCode, Enum.UserInputState.Begin)
        task.wait(holdTime)
        UIS:SendKeyEvent(keyCode, Enum.UserInputState.End)
    end)
    
    if success then
        print("⌨️ 按住按键: " .. keyName .. " (" .. holdTime .. "s)")
    end
    return success
end

-- 输入字符串（逐字输入）
local function typeString(text, delay)
    delay = delay or 0.05
    for i = 1, #text do
        local char = text:sub(i, i)
        local upper = char:upper()
        local keyCode = KEY_MAP[upper]
        if keyCode then
            pcall(function()
                UIS:SendKeyEvent(keyCode, Enum.UserInputState.Begin)
                task.wait(0.02)
                UIS:SendKeyEvent(keyCode, Enum.UserInputState.End)
            end)
        end
        task.wait(delay)
    end
    print("⌨️ 输入文本: " .. text)
end

