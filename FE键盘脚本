-- ===============================
-- 按钮生成器
-- ===============================
local function btn(text, cb)
    local b = safeCreate("TextButton", {
        Size = UDim2.new(1, -12, 0, 34),
        BackgroundColor3 = Color3.fromRGB(45, 45, 60),
        Text = text,
        TextColor3 = Color3.fromRGB(255, 255, 255),
        Font = Enum.Font.Gotham,
        TextSize = 12,
        Parent = Content
    })
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
    b.MouseButton1Click:Connect(function()
        pcall(cb)
    end)
end

-- ===============================
-- 键盘模拟（✅ 游戏能识别）
-- ===============================
local function pressKey(k)
    local code = Enum.KeyCode[k]
    if code then
        UIS:SendKeyEvent(code, Enum.UserInputState.Begin)
        task.wait(0.05)
        UIS:SendKeyEvent(code, Enum.UserInputState.End)
    end
end

btn("⬆ 按 W", function() pressKey("W") end)
btn("⏹ 空格", function() pressKey("SPACE") end)
btn("📋 Ctrl + V", function()
    pressKey("LEFTCTRL")
    pressKey("V")
end)

