--[[
========================================
Old Cat Cheat - Loader v5.1 (Fixed)
✅ 修复 Base64 拼接错误
✅ 防 HttpGet 拦截
✅ 手机端可用
========================================
]]

local HttpService = game:GetService("HttpService")

-- ★★★ 你的 Base64（不要动这里）★★★
local EncodedScript = ""

-- 安全执行（修复版）
local success, result = pcall(function()
    -- 关键修复：正确拼接引号
    local decoded = HttpService:JSONDecode('"' .. EncodedScript .. '"')
    loadstring(decoded)()
end)

if not success then
    warn("❌ Old Cat Cheat 加载失败！")
    warn("错误详情：", result)
    
    local sg = Instance.new("ScreenGui", game:GetService("CoreGui"))
    local fr = Instance.new("Frame", sg)
    fr.Size = UDim2.new(0, 300, 0, 100)
    fr.Position = UDim2.new(0.5, -150, 0.5, -50)
    fr.BackgroundColor3 = Color3.fromRGB(40, 0, 0)
    fr.BorderSizePixel = 0
    
    local txt = Instance.new("TextLabel", fr)
    txt.Size = UDim2.new(1, -20, 1, -20)
    txt.Position = UDim2.new(0, 10, 0, 10)
    txt.Text = "脚本加载失败！\n请检查 Base64 是否正确。"
    txt.TextColor3 = Color3.new(1, 1, 1)
    txt.Font = Enum.Font.SourceSansBold
    txt.TextSize = 14
    txt.TextWrapped = true
end
