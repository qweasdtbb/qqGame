local function verify()
    if not CORRECT_DATA then
        Status.Text = "❌ 该账号无权限"
        task.wait(1.5)
        LocalPlayer:Kick("请联系老猫作者")
        return
    end

    if os.time() > CORRECT_DATA.Expire then
        Status.Text = "❌ 密钥已过期"
        task.wait(1.5)
        LocalPlayer:Kick("密钥已过期")
        return
    end

    if KeyBox.Text == CORRECT_DATA.Key then
        KeyFrame:Destroy()
        loadMainUI()
    else
        Status.Text = "❌ 密钥错误"
        task.wait(1.5)
        LocalPlayer:Kick("请联系老猫作者")
    end
end

Submit.MouseButton1Click:Connect(verify)
KeyBox.FocusLost:Connect(function(e) if e then verify() end end)

