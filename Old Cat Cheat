    CreateSlider(CombatTab, "自动开枪", 20, function(s) trigger = s end)

    RunService.RenderStepped:Connect(function()
        if trigger then
            local result = workspace:Raycast(
                Camera.CFrame.Position,
                Camera.CFrame.LookVector * 1000
            )
            if result then mouse1click() end
        end
    end)

    -- ===== 玩家功能 =====
    CreateSlider(PlayerTab, "飞行", 20, function(s)
        -- 简化示例
    end)

    HomeTab.Visible = true
    print("✅ 老猫脚本 0.08v 已加载")
end

