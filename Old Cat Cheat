local pages, menuBtns = {}, {}
local function createTab(name, index)
    local btn = Instance.new("TextButton", Menu); btn.Size = UDim2.new(1, 0, 0, 36); btn.Position = UDim2.new(0, 0, 0, (index-1)*36)
    btn.Text = L[CL].Tabs[name]; btn.BackgroundColor3 = Color3.fromRGB(45, 45, 55); btn.TextColor3 = Color3.new(1,1,1)
    local page = Instance.new("ScrollingFrame", Content); page.Size = UDim2.new(1, -10, 1, -10); page.Position = UDim2.new(0, 5, 0, 5)
    page.BackgroundTransparency = 1; page.Visible = false
    btn.MouseButton1Click:Connect(function() for _,p in pairs(pages) do p.Visible=false end page.Visible=true end)
    pages[name] = page; table.insert(menuBtns, btn)
    return page
end

