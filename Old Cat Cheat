-- // ====================== 异步脚本加载 ====================== \\
local function safeLoadScript(url, button, successText)
    button.Text = "加载中..."
    button.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    task.spawn(function()
        local ok, scr = pcall(game.HttpGet, game, url, true)
        if ok and scr and scr ~= "" then
            local s, err = pcall(loadstring, scr)
            if s then
                button.Text = successText or "加载成功!"
                button.BackgroundColor3 = Color3.fromRGB(50, 180, 50)
            else
                button.Text = "执行失败"
                button.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
                warn("脚本执行错误:", err)
            end
        else
            button.Text = "下载失败"
            button.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
        end
        task.wait(2)
        button.Text = button.originalText or button.Text
        button.BackgroundColor3 = button.originalColor or Color3.fromRGB(60, 120, 180)
    end)
end

-- // ====================== Anti-AFK ====================== \\
local function startAntiAFK()
    antiAFKConn = RS.RenderStepped:Connect(function()
        local now = tick()
        if not startAntiAFK.time then startAntiAFK.time = now end
        if now - startAntiAFK.time >= CONFIG.AntiAFK_Interval then
            startAntiAFK.time = now
            pcall(function()
                mousemoverel(1, 0)
                task.wait(0.05)
                mousemoverel(-1, 0)
            end)
        end
    end)
end

