-- // ====================== 服务与状态 ====================== \\
local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local permissionLevel = "NORMAL" -- OWNER, ADMIN, NORMAL, BLACKLIST
local isFlying = false
local flyConnection

-- // ====================== 权限验证 ====================== \\
local function checkPermission()
    if CONFIG.Owners[LP.Name] then
        permissionLevel = "OWNER"
        return true
    elseif CONFIG.Blacklist[LP.Name] then
        permissionLevel = "BLACKLIST"
        LP:Kick(L[currentLang].Kicked)
        return false
    elseif CONFIG.Whitelist[LP.Name] then
        permissionLevel = "ADMIN"
        return true
    else
        permissionLevel = "NORMAL"
        return false -- 需要密钥
    end
end

-- // ====================== UI 创建函数 ====================== \\
local function createUI()
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "LaoMaoLoader"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.Parent = game.CoreGui

    local MainFrame = Instance.new("Frame")
    MainFrame.Size = UDim2.new(0.7, 0, 0.7, 0)
    MainFrame.Position = UDim2.new(0.15, 0, 0.15, 0)
    MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    MainFrame.BorderSizePixel = 0
    MainFrame.Active = true
    MainFrame.Draggable = true
    MainFrame.Parent = ScreenGui

    -- 标题栏
    local TitleBar = Instance.new("Frame", MainFrame)
    TitleBar.Size = UDim2.new(1, 0, 0.08, 0)
    TitleBar.BackgroundColor3 = Color3.fromRGB(40, 40, 55)

    local TitleLabel = Instance.new("TextLabel", TitleBar)
    TitleLabel.Size = UDim2.new(1, -100, 1, 0)
    TitleLabel.Position = UDim2.new(0, 10, 0, 0)
    TitleLabel.Text = L[currentLang].Title .. (permissionLevel == "OWNER" and " [OWNER]" or "")
    TitleLabel.TextColor3 = Color3.fromRGB(255, 200, 80)
    TitleLabel.Font = Enum.Font.SourceSansBold
    TitleLabel.TextSize = 16
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

    -- 关闭按钮
    local CloseBtn = Instance.new("TextButton", TitleBar)
    CloseBtn.Size = UDim2.new(0, 30, 0, 30)
    CloseBtn.Position = UDim2.new(1, -32, 0, 2)
    CloseBtn.Text = "X"
    CloseBtn.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
    CloseBtn.TextColor3 = Color3.new(1,1,1)
    CloseBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

    -- 左侧菜单
    local MenuFrame = Instance.new("Frame", MainFrame)
    MenuFrame.Size = UDim2.new(0.2, 0, 0.92, 0)
    MenuFrame.Position = UDim2.new(0, 0, 0.08, 0)
    MenuFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 45)

    -- 右侧内容
    local ContentFrame = Instance.new("Frame", MainFrame)
    ContentFrame.Size = UDim2.new(0.8, 0, 0.92, 0)
    ContentFrame.Position = UDim2.new(0.2, 0, 0.08, 0)
    ContentFrame.BackgroundColor3 = Color3.fromRGB(45, 45, 55)

    -- Tab 管理
    local tabs = {}
    local contents = {}
    
    local function createTab(name, index)
        local btn = Instance.new("TextButton", MenuFrame)
        btn.Size = UDim2.new(1, 0, 0, 40)
        btn.Position = UDim2.new(0, 0, 0, (index-1)*40)
        btn.Text = L[currentLang].Tabs[name]
        btn.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
        btn.TextColor3 = Color3.new(1,1,1)
        btn.Font = Enum.Font.SourceSans
        btn.TextSize = 14
        
        local frame = Instance.new("Frame", ContentFrame)
        frame.Size = UDim2.new(1, 0, 1, 0)
        frame.BackgroundTransparency = 1
        frame.Visible = false
        
        btn.MouseButton1Click:Connect(function()
            for _, c in pairs(contents) do c.Visible = false end
            frame.Visible = true
        end)
        
        tabs[name] = btn
        contents[name] = frame
        return frame
    end

    -- 创建各个页面
    local homeFrame = createTab("Home", 1)
    local playerFrame = createTab("Player", 2)
    local skinFrame = createTab("Skin", 3)
    local generalFrame = createTab("General", 4)
    local aboutFrame = createTab("About", 5)
    
    -- 所有者专属 Tab
    local devFrame
    if permissionLevel == "OWNER" then
        devFrame = createTab("Dev", 6)
        -- 开发者面板内容
        local devTitle = Instance.new("TextLabel", devFrame)
        devTitle.Size = UDim2.new(1, 0, 0, 30)
        devTitle.Text = L[currentLang].DevPanel.Title
        devTitle.Font = Enum.Font.SourceSansBold
        devTitle.TextSize = 18

        local function createAdminInput(yPos, buttonText, list, actionText)
            local input = Instance.new("TextBox", devFrame)
            input.Size = UDim2.new(0.6, 0, 0, 30)
            input.Position = UDim2.new(0.05, 0, 0, yPos)
            input.PlaceholderText = L[currentLang].DevPanel.Placeholder
            
            local btn = Instance.new("TextButton", devFrame)
            btn.Size = UDim2.new(0.3, 0, 0, 30)
            btn.Position = UDim2.new(0.65, 0, 0, yPos)
            btn.Text = buttonText
            btn.BackgroundColor3 = Color3.fromRGB(70, 130, 70)
            btn.MouseButton1Click:Connect(function()
                local user = input.Text
                if user ~= "" then
                    list[user] = (actionText == "add")
                    print(string.format("%s %s", user, actionText == "add" and "added to list" or "removed from list"))
                end
            end)
        end
        
        createAdminInput(50, L[currentLang].DevPanel.AddWhite, CONFIG.Whitelist, "add")
        createAdminInput(100, L[currentLang].DevPanel.RemoveWhite, CONFIG.Whitelist, "remove")
        createAdminInput(160, L[currentLang].DevPanel.AddBlack, CONFIG.Blacklist, "add")
        createAdminInput(210, L[currentLang].DevPanel.RemoveBlack, CONFIG.Blacklist, "remove")
    end

    -- 默认显示首页
    contents["Home"].Visible = true

    -- (此处省略 Player, Skin, General, About 页面的具体控件创建代码，以保持简洁)
    -- 这些页面的创建逻辑与你之前的版本类似，主要是填充到对应的 Frame 中
    -- 例如 Player 页面：
    local flyBtn = Instance.new("TextButton", playerFrame)
    flyBtn.Size = UDim2.new(0.8, 0, 0, 40)
    flyBtn.Position = UDim2.new(0.1, 0, 0.1, 0)
    flyBtn.Text = "Toggle Fly"
    flyBtn.MouseButton1Click:Connect(function()
        -- 飞行逻辑 (简化版)
        isFlying = not isFlying
        if isFlying then
            flyConnection = RunService.RenderStepped:Connect(function()
                local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    root.Velocity = Vector3.new(0, 50, 0) -- 简易飞行
                end
            end)
        else
            if flyConnection then flyConnection:Disconnect() end
        end
    end)

    return ScreenGui
end

-- // ====================== 主程序入口 ====================== \\
local function main()
    if not checkPermission() then
        -- 普通用户需要密钥
        local attempts = CONFIG.MaxAttempts
        -- 这里简化密钥验证，实际应使用 TextBox
        if attempts <= 0 then
            LP:Kick(L[currentLang].Kicked)
            return
        end
    end
    
    -- 权限通过，创建UI
    createUI()
end

main()
