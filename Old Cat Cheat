    btn.Font = Enum.Font.SourceSans; btn.TextSize = 14; local TC = Instance.new("UICorner", btn); TC.CornerRadius = UDim.new(0, 8)
    local page = Instance.new("ScrollingFrame", Content)
    page.Size = UDim2.new(1, -10, 1, -10); page.Position = UDim2.new(0, 5, 0, 5)
    page.BackgroundTransparency = 1; page.ScrollBarThickness = 5; page.Visible = false
    btn.MouseButton1Click:Connect(function() for _,p in pairs(pages) do p.Visible=false end; page.Visible=true end)
    pages[name] = page; table.insert(menuBtns, btn)
    return page
end

