local Attempts = 3
local function CheckKey()
    if KeyBox.Text == CONFIG.CorrectKey then
        KeyFrame.Visible = false
        MainFrame.Visible = true
        RefreshUI()
        print("Key verified! Welcome to Old Cat Cheat!")
    else
        Attempts = Attempts - 1
        if Attempts <= 0 then
            ScreenGui:Destroy()
            warn("Too many failed attempts. Script closed.")
        else
            KeyErrorLabel.Text = Language[CurrentLang].KeyError .. " " .. string.format(Language[CurrentLang].KeyAttempts, Attempts)
            KeyErrorLabel.Visible = true
            KeyBox.Text = ""
        end
    end
end

KeyConfirmBtn.MouseButton1Click:Connect(CheckKey)
KeyBox.FocusLost:Connect(function(enterPressed)
