-- 🧩 UI 构造函数
------------------------------------------------
local function CreateFrame(props)
    local f = Instance.new("Frame")
    f.Size = props.Size or UDim2.new(1,0,1,0)
    f.Position = props.Position or UDim2.new(0,0,0,0)
    f.BackgroundColor3 = props.Bg or Color3.fromRGB(25,25,25)
    f.BorderSizePixel = 0
    f.Parent = props.Parent
    if props.Corner then
        Instance.new("UICorner", f).CornerRadius = UDim.new(0,props.Corner)
    end
    return f
end

local function CreateLabel(parent, text, y)
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(1,-40,0,26)
    l.Position = UDim2.new(0,20,y)
    l.BackgroundTransparency = 1
    l.Text = text
    l.TextColor3 = Color3.fromRGB(255,255,255)
    l.Font = Enum.Font.SourceSans
    l.TextSize = 14
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.Parent = parent
    return l
end

local function CreateSlider(parent, text, y, callback)
    local frame = CreateFrame({
        Size = UDim2.new(1,-40,0,34),
        Position = UDim2.new(0,20,y),
        Bg = Color3.fromRGB(35,35,35),
        Corner = 6,
        Parent = parent
    })

    local label = CreateLabel(frame, text, 0)
    label.Size = UDim2.new(0.6,0,1,0)

    local bar = CreateFrame({
        Size = UDim2.new(0.35,0,0,18),
        Position = UDim2.new(0.63,0,0.5,-9),
        Bg = Color3.fromRGB(60,60,60),
        Corner = 1,
        Parent = frame
    })

    local fill = CreateFrame({
        Size = UDim2.new(0,0,1,0),
        Bg = Color3.fromRGB(0,200,100),
        Corner = 1,
        Parent = bar
    })

    local state = false
    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            state = not state
            TweenService:Create(fill, TweenInfo.new(0.15), {
                Size = UDim2.new(state and 1 or 0,0,1,0)
            }):Play()
            callback(state)
        end
    end)

    return function() return state end
end

