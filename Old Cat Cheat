------------------------------------------------
-- 🎨 UI 构件
------------------------------------------------
local function Frame(siz,pos,bg,par)
    local f=Instance.new("Frame")
    f.Size=siz f.Position=pos f.BackgroundColor3=bg
    f.BorderSizePixel=0 f.Parent=par
    Instance.new("UICorner",f).CornerRadius=UDim.new(0,10)
    return f
end

local function Label(txt,par,y,clr)
    clr=clr or Color3.new(1,1,1)
    local l=Instance.new("TextLabel")
    l.Size=UDim2.new(1,-30,0,28)
    l.Position=UDim2.new(0,15,y)
    l.BackgroundTransparency=1 l.Text=txt
    l.TextColor3=clr l.Font=Enum.Font.SourceSans
    l.TextSize=14 l.TextXAlignment=Enum.TextXAlignment.Left
    l.Parent=par
    return l
end

local function Btn(txt,par,y,cb)
    local b=Instance.new("TextButton")
    b.Size=UDim2.new(1,-30,0,36)
    b.Position=UDim2.new(0,15,y)
    b.BackgroundColor3=Color3.fromRGB(0,160,255)
    b.Text=txt b.TextColor3=Color3.new(1,1,1)
    b.Font=Enum.Font.SourceSansBold b.TextSize=15
    b.Parent=par
    Instance.new("UICorner",b).CornerRadius=UDim.new(0,8)
    b.MouseButton1Click:Connect(cb)
    return b
end

------------------------------------------------
-- 🪟 主窗口（仿你截图暗黑悬浮）
------------------------------------------------
local MF = Frame(UDim2.new(0,400,0,320),UDim2.new(0.5,-200,0.5,-160),
                 Color3.fromRGB(20,20,20),SG)
MF.Active=true MF.Draggable=true

-- Logo / 标题
Label("🐱  Old Cat Cheat  v0.09",MF,12,Color3.fromRGB(0,255,127)).Font=Enum.Font.SourceSansBold

local Info = Label("",MF,50,Color3.fromRGB(200,200,200))

local function LaunchScript()
    Info.Text="⏳ 正在加载脚本..."
    Info.TextColor3=Color3.fromRGB(255,255,0)
    local ok,err=pcall(function()
        loadstring(game:HttpGet(ScriptURL,true))()
    end)
    if ok then
        Info.Text="✅  注入成功！"
        Info.TextColor3=Color3.fromRGB(0,255,100)
        task.wait(1.5)
        SG:Destroy()
    else
        Info.Text="❌  加载失败:\n"..tostring(err)
        Info.TextColor3=Color3.fromRGB(255,60,60)
    end
end

