local isFlying = false
local flyConn
flyBtn.MouseButton1Click:Connect(function()
    isFlying = not isFlying
    if isFlying then
        hum.PlatformStand = true
        local root = char:WaitForChild("HumanoidRootPart")
        flyConn = RS.RenderStepped:Connect(function()
            local cam = workspace.CurrentCamera
            local d = Vector3.zero
            if UIS:IsKeyDown(Enum.KeyCode.W) then d = d + cam.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.S) then d = d - cam.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.A) then d = d - cam.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.D) then d = d + cam.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.Space) then d = d + Vector3.yAxis end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then d = d - Vector3.yAxis end
            if d.Magnitude > 0 then
                root.Velocity = d.Unit * 50
            else
                root.Velocity = Vector3.new(0, 0, 0)
            end
        end)
        flyBtn.Text = L[CL].Fly .. ": " .. L[CL].On
        flyBtn.BackgroundColor3 = Color3.fromRGB(50, 180, 50)
    else
        hum.PlatformStand = false
        if flyConn then flyConn:Disconnect() end
        flyBtn.Text = L[CL].Fly .. ": " .. L[CL].Off
        flyBtn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
    end
end)

