local function CreateToggle(name, yOffset, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.8, 0, 0, 40)
    btn.Position = UDim2.new(0.1, 0, yOffset, 0)
    btn.BackgroundColor3 = Color3.fromRGB(120, 60, 60)
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 16
    btn.Text = name .. ": OFF"
    btn.Parent = PlayerContent

    local enabled = false
    btn.MouseButton1Click:Connect(function()
        enabled = not enabled
        btn.Text = name .. (enabled and ": ON" or ": OFF")
        btn.BackgroundColor3 = enabled and Color3.fromRGB(60,120,60) or Color3.fromRGB(120,60,60)
        callback(enabled)
    end)
end

CreateToggle(Language[CurrentLang].Placeholders.Speed == "输入速度" and "速度" or "Speed", 0.05, function(enabled)
