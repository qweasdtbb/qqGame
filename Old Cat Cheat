-- 🔐 普通用户 → 密钥验证
------------------------------------------------
else
    Info.Text="请输入你的专属密钥"
    Info.TextColor3=Color3.fromRGB(200,200,200)

    local KB=Instance.new("TextBox")
    KB.Size=UDim2.new(1,-30,0,34)
    KB.Position=UDim2.new(0,15,0,95)
    KB.BackgroundColor3=Color3.fromRGB(35,35,35)
    KB.TextColor3=Color3.new(1,1,1)
    KB.PlaceholderText="LAOMAO-XXXXXX"
    KB.Font=Enum.Font.SourceSans KB.TextSize=14 KB.Parent=MF
    Instance.new("UICorner",KB).CornerRadius=UDim.new(0,8)

    local ErrLbl=Label("",MF,138,Color3.fromRGB(255,80,80))

    Btn("🔓  验证 & 启动",MF,170,function()
        if not MyData then
            ErrLbl.Text="❌  此账号未分配密钥"
            return
        end
        if os.time()>MyData.Exp then
            ErrLbl.Text="❌  密钥已过期，联系老猫"
            return
        end
        if KB.Text==MyData.Key then
            LaunchScript()
        else
            ErrLbl.Text="❌  密钥错误"
        end
    end)
end

