        Size = UDim2.new(1,0,0,46),
        Bg = Color3.fromRGB(35,35,35),
        Corner = 12,
        Parent = MainFrame
    })

    CreateLabel(TitleBar, "🐱 老猫脚本 0.08v", 0).Font = Enum.Font.SourceSansBold

    -- Tab 栏
    local TabList = CreateFrame({
        Size = UDim2.new(0,130,1,-46),
        Bg = Color3.fromRGB(25,25,25),
        Parent = MainFrame
    })

    local Content = CreateFrame({
        Size = UDim2.new(1,-130,1,-46),
        Position = UDim2.new(0,130,0,46),
        Bg = Color3.fromRGB(15,15,15),
        Parent = MainFrame
    })

    local function CreateTab(name)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1,-10,0,32)
        btn.Position = UDim2.new(0,5,#TabList:GetChildren()*36)
        btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
        btn.Text = name
        btn.TextColor3 = Color3.fromRGB(255,255,255)
        btn.Font = Enum.Font.SourceSans
        btn.TextSize = 14
        btn.Parent = TabList
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0,6)

        local page = CreateFrame({
            Size = UDim2.new(1,0,1,0),
            Bg = Color3.fromRGB(15,15,15),
            Parent = Content
        })
        page.Visible = false

        btn.MouseButton1Click:Connect(function()
            for _,v in ipairs(Content:GetChildren()) do
                if v:IsA("Frame") then v.Visible = false end
            end
            page.Visible = true
        end)

        return page
    end

    local HomeTab = CreateTab("🏠 主页")
    local CombatTab = CreateTab("🎯 战斗")
    local PlayerTab = CreateTab("🎮 玩家")

    -- ===== 主页 =====
